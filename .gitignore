# Dependencies
node_modules/

# Build output
dist/
coverage/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Cursor & Kilo (tool configs — track shared rules, ignore local/ephemeral state)
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.kilo/

# AI-generated plan / working-doc files (ephemeral, regenerated by assistants)
# Specific tool locations (some redundant with the .cursor/.kilo parent rules
# above — kept explicit so plans stay ignored even if those parents move):
.kilo/plans/
.cursor/plans/
.claude/plans/
# Generic: any plans/ directory or plan-named markdown file at any depth
**/plans/
**/plan.md
**/plans.md
**/*-plan.md
**/*-plans.md
**/plan-*.md
**/plans-*.md
**/EXECUTION_PLAN.md
**/execution-plan.md

# Playwright MCP snapshots (ephemeral)
.playwright-mcp/

# Env
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Vitest / test artifacts
*.log
test-results/
playwright-report/
html-report/

# Temporary
tmp/
*.tmp
tools-en-export.json
tools-en-compact.json

# TypeScript
*.tsbuildinfo

# ESLint cache
.eslintcache

# Prettier
.prettiercache

# Source maps
*.map

# Article authoring drafts at articles/ root (not built or linked from the site).
# Shipped pages live in articles/<slug>/index.html and must be tracked for CI/build.
articles/*.md

# Verification / audit run artifacts
# Full per-tool report (regenerated on every run, big, not for repo):
verification-results.json
# Date-stamped summaries under docs/verification/ are intentionally tracked
