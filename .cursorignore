# =============================================================================
# .cursorignore — Cursor AI indexing exclusions
# =============================================================================
# Syntax: same as .gitignore. Paths are relative to repo root.
# Goal: keep Cursor focused on source code, tests, docs, and config that matter.

# -----------------------------------------------------------------------------
# Dependencies (massive, not useful for code understanding)
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build output & artifacts
# -----------------------------------------------------------------------------
dist/
coverage/

# -----------------------------------------------------------------------------
# Lock files (huge, auto-generated, no semantic value for AI)
# -----------------------------------------------------------------------------
package-lock.json

# -----------------------------------------------------------------------------
# Playwright MCP logs & snapshots (ephemeral debug output)
# -----------------------------------------------------------------------------
.playwright-mcp/

# -----------------------------------------------------------------------------
# Kilo config & session data (separate tool, not relevant in Cursor)
# -----------------------------------------------------------------------------
.kilo/

# -----------------------------------------------------------------------------
# Git internals
# -----------------------------------------------------------------------------
.git/

# -----------------------------------------------------------------------------
# Logs & temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
console.log

# -----------------------------------------------------------------------------
# Binary / media files (no semantic value for code AI)
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.eot

# -----------------------------------------------------------------------------
# CI/CD workflows (rarely relevant when writing application code)
# -----------------------------------------------------------------------------
.github/

# -----------------------------------------------------------------------------
# Blog articles (content, not application code)
# -----------------------------------------------------------------------------
articles/

# -----------------------------------------------------------------------------
# Editor / OS artifacts
# -----------------------------------------------------------------------------
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# -----------------------------------------------------------------------------
# Environment files (secrets, local config)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Source maps (generated, not useful for AI)
# -----------------------------------------------------------------------------
*.map
