# CODEOWNERS — automatically requests reviews from the listed owners
# when a PR touches the matching paths.
#
# On the GitHub Free plan, CODEOWNES are not enforced for branch protection
# unless the repo also has branch protection rules. They DO, however, work
# as PR-review request signals regardless of plan.

# Default owners for everything in the repo.
*                           @banal-contributors

# Workflow and CI/CD — be careful, breaks deploys.
/.github/                   @banal-contributors

# Security-sensitive: secrets, key handling, pentest results.
# NOTE: src/auth, src/security, src/crypto do not exist in this repo today.
# Add the corresponding glob back here if those directories are ever created.
SECURITY.md                 @banal-contributors
PENTEST_REPORT.md           @banal-contributors

# Tool database — owners review when external URLs / categories change.
/src/data/                  @banal-contributors
/scripts/verify-tools.ts    @banal-contributors
