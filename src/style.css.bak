@tailwind base;
@tailwind components;
@tailwind utilities;

/* ============================================================
   BANAL AI — PREMIUM MINIMAL DESIGN
   Glassmorphism + big bold search + huge visibility
   ============================================================ */

:root {
  --glass-bg: rgba(255, 255, 255, 0.03);
  --glass-border: rgba(255, 255, 255, 0.08);
  --glass-hover: rgba(255, 255, 255, 0.06);
  --violet-glow: rgba(124, 58, 237, 0.4);
  --violet-soft: rgba(168, 85, 247, 0.15);
}

/* === SEARCH HERO — THE STAR === */
.hero-search-wrapper {
  position: relative;
  max-width: 800px;
  margin: 0 auto;
}

.hero-search-input {
  width: 100%;
  padding: 24px 32px;
  font-size: 1.25rem;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.04);
  border: 2px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  color: #fff;
  outline: none;
  transition: all 0.3s ease;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.hero-search-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
  font-size: 1.1rem;
}

.hero-search-input:focus {
  border-color: rgba(168, 85, 247, 0.6);
  background: rgba(255, 255, 255, 0.07);
  box-shadow:
    0 0 0 4px rgba(124, 58, 237, 0.15),
    0 20px 60px -15px rgba(124, 58, 237, 0.3);
}

.hero-search-icon {
  position: absolute;
  right: 28px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1.5rem;
  opacity: 0.5;
  pointer-events: none;
}

/* === STATS BAR — BIG NUMBERS === */
.stats-bar {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  overflow: hidden;
  max-width: 700px;
  margin: 0 auto;
}

.stat-item {
  background: rgba(255, 255, 255, 0.02);
  padding: 28px 20px;
  text-align: center;
  transition: background 0.3s ease;
}

.stat-item:hover {
  background: rgba(168, 85, 247, 0.08);
}

.stat-number {
  font-size: 3rem;
  font-weight: 900;
  line-height: 1;
  background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.6) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8px;
}

.stat-label {
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
  letter-spacing: 0.15em;
}

/* === CATEGORY PILLS — BIG TAP TARGETS === */
.category-pill-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  max-width: 900px;
  margin: 0 auto;
}

.category-pill {
  padding: 14px 24px;
  border-radius: 100px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.25s ease;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.category-pill:hover {
  background: rgba(168, 85, 247, 0.12);
  border-color: rgba(168, 85, 247, 0.4);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 10px 40px -10px rgba(124, 58, 237, 0.4);
}

.category-pill.active {
  background: rgba(124, 58, 237, 0.2);
  border-color: rgba(168, 85, 247, 0.6);
  color: #fff;
}

.category-pill-icon {
  font-size: 1.2rem;
}

/* === TOOL LIST — BIG CLEAN ROWS === */
.tool-list-container {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24px;
  overflow: hidden;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.tool-row-header {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 16px;
  align-items: center;
  padding: 18px 28px;
  background: rgba(255, 255, 255, 0.02);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  font-size: 0.7rem;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  text-transform: uppercase;
  letter-spacing: 0.15em;
}

.tool-row {
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  transition: background 0.2s ease;
}

.tool-row:last-child {
  border-bottom: none;
}

.tool-row:hover {
  background: rgba(255, 255, 255, 0.02);
}

.tool-row-summary {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 16px;
  align-items: center;
  padding: 18px 28px;
  cursor: pointer;
  list-style: none;
}

.tool-row-summary::-webkit-details-marker {
  display: none;
}

.tool-row-summary::marker {
  content: '';
}

.tool-row-name {
  font-size: 1.05rem;
  font-weight: 700;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 12px;
}

.tool-row-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.5);
  font-size: 0.8rem;
  transition: all 0.2s ease;
}

details[open] .tool-row-arrow {
  transform: rotate(90deg);
  background: rgba(168, 85, 247, 0.2);
  color: #c4b5fd;
}

.tool-row-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tool-badge {
  padding: 4px 12px;
  border-radius: 100px;
  background: rgba(168, 85, 247, 0.1);
  border: 1px solid rgba(168, 85, 247, 0.2);
  color: #c4b5fd;
  font-size: 0.75rem;
  font-weight: 600;
}

.tool-row-surface {
  font-size: 0.75rem;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 6px 14px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.tool-row-open {
  padding: 10px 20px;
  border-radius: 12px;
  background: linear-gradient(135deg, #7c3aed 0%, #d946ef 100%);
  color: #fff;
  font-weight: 600;
  font-size: 0.85rem;
  text-decoration: none;
  transition: all 0.2s ease;
  box-shadow: 0 4px 15px -3px rgba(124, 58, 237, 0.4);
  white-space: nowrap;
}

.tool-row-open:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 25px -5px rgba(124, 58, 237, 0.5);
}

/* === EXPANDED DETAILS PANEL === */
.tool-details-panel {
  padding: 24px 28px;
  background: rgba(0, 0, 0, 0.2);
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  animation: slideDown 0.25s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tool-detail-category {
  font-size: 0.7rem;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 4px;
}

.tool-detail-best {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  margin: 0;
}

.tool-detail-quality {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
  margin: 0;
}

.tool-detail-caveat {
  font-size: 0.8rem;
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.08);
  border-left: 3px solid #f59e0b;
  padding: 8px 12px;
  border-radius: 0 8px 8px 0;
  margin: 0;
  line-height: 1.5;
}

.tool-detail-link {
  font-size: 0.8rem;
  color: #a78bfa;
  text-decoration: none;
  font-weight: 500;
}

.tool-detail-link:hover {
  color: #c4b5fd;
  text-decoration: underline;
}

/* === LIFE FILTERS — CHIP STYLE === */
.life-filters-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  margin-top: 20px;
}

.life-filter-chip {
  padding: 10px 18px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.85rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.life-filter-chip:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.15);
  color: #fff;
}

.life-filter-chip.active {
  background: rgba(124, 58, 237, 0.15);
  border-color: rgba(168, 85, 247, 0.4);
  color: #c4b5fd;
}

/* === SURFACE CHIPS === */
.surface-chips {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin-bottom: 24px;
}

.surface-chip {
  padding: 8px 18px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.surface-chip:hover {
  background: rgba(255, 255, 255, 0.06);
}

.surface-chip.active {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

/* === RESULT STATUS === */
.result-status {
  padding: 14px 24px;
  background: rgba(124, 58, 237, 0.08);
  border: 1px solid rgba(168, 85, 247, 0.2);
  border-radius: 14px;
  color: #c4b5fd;
  font-weight: 600;
  font-size: 0.9rem;
  margin-bottom: 16px;
  text-align: center;
}

.no-matches {
  padding: 40px;
  text-align: center;
  color: rgba(255, 255, 255, 0.4);
  font-size: 1rem;
}

/* === CTA PRIMARY — GLOWING === */
.cta-primary {
  background: linear-gradient(135deg, #7c3aed 0%, #d946ef 100%);
  color: white;
  border: none;
  border-radius: 16px;
  padding: 14px 32px;
  font-weight: 600;
  font-size: 1rem;
  box-shadow: 0 4px 20px -5px rgba(124, 58, 237, 0.5);
  transition: all 0.3s ease;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.cta-primary:hover {
  transform: translateY(-2px);
  box-shadow:
    0 8px 30px -5px rgba(124, 58, 237, 0.6),
    0 0 0 1px rgba(168, 85, 247, 0.3);
}

/* === SECTION EYEBROW === */
.section-eyebrow {
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: #c084fc;
  margin-bottom: 1rem;
  text-align: center;
}

/* === ARTICLES — Coming Soon, viral-feel but honest === */
.article-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 28px;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.article-card:hover {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(168, 85, 247, 0.3);
  transform: translateY(-3px);
  box-shadow: 0 20px 50px -15px rgba(124, 58, 237, 0.3);
}

.article-card-badge {
  display: inline-block;
  padding: 6px 14px;
  border-radius: 100px;
  background: rgba(251, 191, 36, 0.1);
  border: 1px solid rgba(251, 191, 36, 0.25);
  color: #fbbf24;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  width: fit-content;
}

.article-card-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: #fff;
  line-height: 1.35;
  margin: 0;
}

.article-card-excerpt {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.6;
  margin: 0;
  flex-grow: 1;
}

.article-card-meta {
  display: flex;
  gap: 10px;
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.35);
  font-weight: 500;
  padding-top: 8px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

/* === RESPONSIVE === */
@media (max-width: 768px) {
  .stats-bar {
    grid-template-columns: repeat(2, 1fr);
  }

  .stat-number {
    font-size: 2rem;
  }

  .tool-row-summary {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .tool-row-header {
    display: none;
  }

  .tool-details-panel {
    grid-template-columns: 1fr;
  }

  .hero-search-input {
    font-size: 1rem;
    padding: 18px 20px;
  }

  .category-pill {
    padding: 10px 16px;
    font-size: 0.85rem;
  }
}

@media (max-width: 480px) {
  .stats-bar {
    grid-template-columns: 1fr 1fr;
    border-radius: 16px;
  }

  .stat-item {
    padding: 20px 12px;
  }

  .stat-number {
    font-size: 1.75rem;
  }
}

/* === REDUCED MOTION === */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* === FOCUS STATES === */
a:focus-visible,
button:focus-visible,
input:focus-visible {
  outline: 2px solid rgba(168, 85, 247, 0.5);
  outline-offset: 3px;
}

/* === SELECTION === */
::selection {
  background: rgba(168, 85, 247, 0.3);
  color: #fff;
}

/* Smooth scroll */
html {
  scroll-behavior: smooth;
}
