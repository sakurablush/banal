# =============================================================================
# .kiloignore — Kilo AI indexing exclusions
# =============================================================================
# Syntax: same as .gitignore. Paths are relative to repo root.
# Goal: keep Kilo focused on source code, tests, docs, and config that matter.

# -----------------------------------------------------------------------------
# Dependencies (massive, not useful for code understanding)
# -----------------------------------------------------------------------------
node_modules/
.kilo/node_modules/

# -----------------------------------------------------------------------------
# Build output & artifacts
# -----------------------------------------------------------------------------
dist/
coverage/

# -----------------------------------------------------------------------------
# Lock files (huge, auto-generated, no semantic value for AI)
# -----------------------------------------------------------------------------
package-lock.json

# -----------------------------------------------------------------------------
# Playwright MCP logs & snapshots (ephemeral debug output)
# -----------------------------------------------------------------------------
.playwright-mcp/

# -----------------------------------------------------------------------------
# Kilo session plans (historical, not relevant to current code)
# -----------------------------------------------------------------------------
.kilo/plans/

# -----------------------------------------------------------------------------
# Git internals
# -----------------------------------------------------------------------------
.git/

# -----------------------------------------------------------------------------
# Logs & temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
console.log

# -----------------------------------------------------------------------------
# Binary / media files (no semantic value for code AI)
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.woff
*.woff2
*.ttf
*.eot

# -----------------------------------------------------------------------------
# CI/CD workflows (rarely relevant when writing application code)
# -----------------------------------------------------------------------------
.github/

# -----------------------------------------------------------------------------
# Editor / OS artifacts
# -----------------------------------------------------------------------------
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# -----------------------------------------------------------------------------
# Environment files (secrets, local config)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Cursor config (avoid cross-tool noise)
# -----------------------------------------------------------------------------
.cursor/
.cursorignore
